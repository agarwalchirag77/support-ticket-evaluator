# Zendesk credentials
ZENDESK_EMAIL=you@hevodata.com
ZENDESK_API_TOKEN=your_zendesk_api_token_here

# Zendesk group IDs (find via: GET /api/v2/groups.json)
CHAT_L1_GROUP_ID=123456789
GENERAL_ESCALATION_GROUP_ID=987654321

# LLM API keys (only the one you use needs to be set)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Notification: email-to-Slack channel
# Find Slack channel email: Channel > Settings > Integrations > "Send emails to this channel"
NOTIFICATION_EMAIL=alerts@hevodata.com
NOTIFICATION_EMAIL_PASSWORD=your_app_password_here
SLACK_CHANNEL_EMAIL=abc123xyz@hevodata.slack.com

# Optional: Slack webhook (alternative to email-to-Slack)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
